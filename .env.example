# Base URL resmi DashScope (OpenAI-compatible mode)
BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# Mode pengecekan:
#   token = cek otorisasi token/key via GET /models (ringan, tidak makan kuota)
#   model = cek akses langsung ke MODEL via POST /chat/completions
CHECK_MODE=token

# Model yang dicek saat CHECK_MODE=model. Bisa beberapa, pisahkan dengan koma.
# Contoh: MODEL=qwen-plus,qwen-max,qwen-turbo
MODEL=qwen-plus

# Selain file gabungan, tulis juga file terpisah per kategori
# (output/<timestamp>/valid.json, invalid.json, dst). true / false
SPLIT_OUTPUT=true

# File input berisi daftar akun + api_key (default: results.json)
INPUT_FILE=accounts.json

# Folder output hasil pengecekan (default: output)
OUTPUT_DIR=output

# Jumlah pengecekan paralel sekaligus (default: 5)
CONCURRENCY=5

# Timeout per request dalam milidetik (default: 15000)
TIMEOUT_MS=15000
